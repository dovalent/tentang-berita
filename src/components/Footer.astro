---
const currentYear = new Date().getFullYear();

const footerLinks = {
  editorial: [
    { label: 'Tentang Kami', href: '#' },
    { label: 'Redaksi', href: '#' },
    { label: 'Pedoman Media Siber', href: '#' },
    { label: 'Kode Etik Jurnalistik', href: '#' },
  ],
  kategori: [
    { label: 'News', href: '/kategori/news' },
    { label: 'Film & Movie', href: '/kategori/film' },
    { label: 'Game', href: '/kategori/game' },
    { label: 'Lifehacks & Solusi Teknis', href: '/kategori/lifehacks' },
    { label: 'Banyuwangi', href: '/kategori/banyuwangi' },
    { label: 'Opini', href: '/kategori/opini' },
  ],
  legal: [
    { label: 'Syarat & Ketentuan', href: '#' },
    { label: 'Kebijakan Privasi', href: '#' },
    { label: 'Disclaimer', href: '#' },
  ],
};
---

<footer id="site-footer" class="bg-brand-900 text-slate-300 mt-16">
  <!-- Footer Top -->
  <div class="max-w-container mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 group">
          <div class="w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-black text-sm leading-none">TB</span>
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-extrabold text-white tracking-tight leading-none">TENTANG</span>
            <span class="text-[10px] font-semibold text-brand-300 tracking-[0.2em] uppercase leading-none">Berita</span>
          </div>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Portal berita yang menyajikan informasi terkini secara objektif, akurat, dan berbasis data untuk pembaca Indonesia.
        </p>
      </div>

      <!-- Editorial -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Editorial</h4>
        <ul class="space-y-2">
          {footerLinks.editorial.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kategori -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Kategori</h4>
        <ul class="space-y-2">
          {footerLinks.kategori.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Informasi</h4>
        <ul class="space-y-2">
          {footerLinks.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="border-t border-slate-800">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-500">
        &copy; {currentYear} TENTANG Berita. Seluruh hak cipta dilindungi undang-undang.
      </p>
      <p class="text-xs text-slate-600">
        Dibangun dengan <span class="text-brand-400">Astro</span> &middot; Disajikan oleh <span class="text-brand-400">Vercel</span>
      </p>
    </div>
  </div>
</footer>
