---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  publishedTime?: string;
  author?: string;
  canonical?: string;
}

const {
  title,
  description = 'TENTANG Berita — Portal berita terkini yang menyajikan informasi nasional, lifehack, dan opini secara objektif dan berbasis data.',
  image = '/og-default.jpg',
  type = 'website',
  publishedTime,
  author,
  canonical,
} = Astro.props;

const siteUrl = 'https://tentang-berita.vercel.app';
const pageUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary Meta Tags -->
  <title>{title} | TENTANG Berita</title>
  <meta name="title" content={`${title} | TENTANG Berita`} />
  <meta name="description" content={description} />
  <meta name="author" content={author || 'Redaksi TENTANG Berita'} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="TENTANG Berita" />
  <meta property="og:locale" content="id_ID" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {author && <meta property="article:author" content={author} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={pageUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Google Discover: max-image-preview -->
  <meta name="googlebot" content="index, follow, max-image-preview:large" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Styles -->
  <style>
    /* Critical inline CSS to prevent layout shift */
    body { margin: 0; min-height: 100vh; }
    .header-spacer { height: 64px; }
    img { content-visibility: auto; }
  </style>

  <!-- ═══ Google Analytics (GA4) ═══ -->
  <!-- Ganti G-6V7KJYS7FW dengan Measurement ID kamu -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6V7KJYS7FW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-6V7KJYS7FW');
  </script>

  <!-- ═══ Google Search Console Verification ═══ -->
  <!-- Ganti KODE_VERIFIKASI dengan kode dari Search Console -->
  <meta name="google-site-verification" content="KODE_VERIFIKASI" />

  <!-- ═══ Google AdSense ═══ -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8634126835496827" crossorigin="anonymous"></script>

</head>
<body class="font-sans text-brand-900 bg-surface-light antialiased">
  <div class="header-spacer"></div>
  <slot />
</body>
</html>
