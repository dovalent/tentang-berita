---
import MainLayout from '../../layouts/MainLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map((entry) => ({
    params: { slug: entry.data.permalink },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allNews = await getCollection('news');
const relatedArticles = allNews
  .filter((a) => a.data.permalink !== entry.data.permalink)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const formattedDate = new Date(entry.data.date).toLocaleDateString('id-ID', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryClass = {
  news: 'category-badge--news',
  nasional: 'category-badge--nasional',
  film: 'category-badge--film',
  'film & movie': 'category-badge--film',
  game: 'category-badge--game',
  lifehacks: 'category-badge--lifehacks',
  banyuwangi: 'category-badge--banyuwangi',
  opini: 'category-badge--opini',
}[entry.data.category.toLowerCase()] || 'category-badge--default';

// JSON-LD Structured Data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": entry.data.title,
  "image": [entry.data.image_url],
  "datePublished": entry.data.date,
  "dateModified": entry.data.date,
  "author": [{
    "@type": "Person",
    "name": entry.data.author
  }],
  "publisher": {
    "@type": "Organization",
    "name": "TENTANG Berita",
    "logo": {
      "@type": "ImageObject",
      "url": "/favicon.svg"
    }
  },
  "description": entry.data.excerpt,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://tentang-berita.vercel.app/berita/${entry.data.permalink}`
  }
};
---

<MainLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  image={entry.data.image_url}
  type="article"
  publishedTime={entry.data.date}
  author={entry.data.author}
>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article id="article-content" class="max-w-container mx-auto px-4 sm:px-6">
    <!-- Article Header -->
    <header class="max-w-article mx-auto pt-8 pb-6">
      <div class="mb-4">
        <span class={`category-badge ${categoryClass}`}>{entry.data.category}</span>
      </div>

      <h1 class="text-headline-xl text-brand-900 font-serif mb-5 text-balance leading-tight" id="article-title">
        {entry.data.title}
      </h1>

      <p class="text-body-lg text-slate-500 mb-6 leading-relaxed">
        {entry.data.excerpt}
      </p>

      <!-- Author & Date -->
      <div class="flex items-center gap-4 pb-6 border-b border-surface-border">
        <div class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center">
          <span class="text-sm font-bold text-brand-600">{entry.data.author.charAt(0)}</span>
        </div>
        <div>
          <p class="text-sm font-semibold text-brand-900">{entry.data.author}</p>
          <time datetime={entry.data.date} class="text-xs text-slate-400">{formattedDate}</time>
        </div>
      </div>
    </header>

    <!-- Hero Image — 1200px width container for Google Discover -->
    <figure class="max-w-4xl mx-auto mb-10">
      <div class="relative overflow-hidden rounded-xl" style="max-width: 1200px;">
        <img
          src={entry.data.image_url}
          alt={entry.data.title}
          class="w-full h-auto object-cover"
          width="1200"
          height="630"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          id="article-hero-image"
        />
      </div>
      {entry.data.image_caption && (
        <figcaption class="text-xs text-slate-400 mt-3 text-center italic">
          {entry.data.image_caption}
        </figcaption>
      )}
    </figure>

    <!-- Article Body -->
    <div class="max-w-article mx-auto prose-article pb-12">
      <Content />
    </div>

    <!-- Tags -->
    <div class="max-w-article mx-auto pb-8 border-b border-surface-border">
      <div class="flex flex-wrap gap-2">
        {entry.data.tags.map((tag: string) => (
          <span class="inline-block px-3 py-1 bg-slate-100 text-slate-600 text-xs font-medium rounded-full hover:bg-slate-200 transition-colors cursor-pointer">
            #{tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Share Buttons -->
    <div class="max-w-article mx-auto py-8 border-b border-surface-border">
      <p class="text-sm font-semibold text-slate-500 mb-3">Bagikan Artikel</p>
      <div class="flex gap-3">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(`https://tentang-berita.vercel.app/berita/${entry.data.permalink}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 bg-slate-900 text-white text-sm font-medium rounded-lg hover:bg-slate-700 transition-colors"
          id="share-twitter"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Bagikan
        </a>
        <a
          href={`https://wa.me/?text=${encodeURIComponent(entry.data.title + ' — ' + `https://tentang-berita.vercel.app/berita/${entry.data.permalink}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors"
          id="share-whatsapp"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section id="related-articles" class="max-w-container mx-auto px-4 sm:px-6 py-12">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-headline-md text-brand-900 whitespace-nowrap">Artikel Terkait</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-surface-border to-transparent"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            permalink={article.data.permalink}
            date={article.data.date}
            author={article.data.author}
            category={article.data.category}
            image_url={article.data.image_url}
            excerpt={article.data.excerpt}
          />
        ))}
      </div>
    </section>
  )}

</MainLayout>
